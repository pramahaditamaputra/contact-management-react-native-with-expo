{
  "expo": {
    "name": "Contact Management",
    "slug": "contact-management-react-native-with-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/splash-icon.svg",
    "scheme": "contactmanagementreactnativewithexpo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/splash-icon.svg",
      "bundleIdentifier": "com.pramahaditamaputra.contactmanagementreactnativewithexpo"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/splash-icon.svg",
        "backgroundImage": "./assets/images/splash-icon.svg",
        "monochromeImage": "./assets/images/splash-icon.svg"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.pramahaditamaputra.contactmanagementreactnativewithexpo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/splash-icon.svg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.svg",
            "imageWidth": 76
          },
          "ios": {
            "image": "./assets/images/splash-icon.svg",
            "imageWidth": 76
          }
        }
      ],
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6671435f-8039-4617-a728-c5c0f31b84a3"
      }
    }
  }
}
